{
  // Angular frontend debugging configuration for VS Code
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Angular + Chrome",
      "type": "chrome",
      "request": "launch",
      "preLaunchTask": "frontend: ng serve",
      "url": "http://localhost:4200/",
      "webRoot": "${workspaceFolder}/frontend",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack:/*": "${webRoot}/*",
        "webpack:///./*": "${webRoot}/*",
        "webpack:///src/*": "${webRoot}/src/*",
        "webpack:///*": "*",
        "webpack:///./~/*": "${webRoot}/node_modules/*"
      }
    },
    {
      "name": "ng test",
      "type": "chrome",
      "request": "launch",
      "preLaunchTask": "frontend: ng test",
      "url": "http://localhost:9876/debug.html"
    }
  ]
}
